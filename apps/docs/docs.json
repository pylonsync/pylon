{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Pylon",
  "description": "The realtime backend framework. Schema, policies, functions, live queries, auth — one binary.",
  "colors": {
    "primary": "#8B5CF6",
    "light": "#A78BFA",
    "dark": "#7C3AED"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "background": {
    "color": {
      "dark": "#0A0A0C",
      "light": "#FFFFFF"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "quickstart",
              "installation"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/entities",
              "concepts/policies",
              "concepts/functions",
              "concepts/live-queries"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/pylonsync/pylon",
          "icon": "github"
        },
        {
          "anchor": "Changelog",
          "href": "https://github.com/pylonsync/pylon/releases",
          "icon": "timeline"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/pylonsync/pylon"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "/quickstart"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/pylonsync/pylon"
    }
  }
}
