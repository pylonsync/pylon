{
  "name": "pylon",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "apps/*",
    "packages/*",
    "examples/*",
    "examples/*/web"
  ],
  "devDependencies": {
    "typescript": "^5.9.3"
