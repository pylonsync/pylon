{
  "manifest_version": 1,
  "name": "todo-app",
  "version": "0.1.0",
  "entities": [
    {
      "name": "User",
      "fields": [
        {
          "name": "email",
          "type": "string",
          "optional": false,
          "unique": true
        },
        {
          "name": "displayName",
          "type": "string",
          "optional": false,
          "unique": false
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "optional": false,
          "unique": false
        }
      ],
      "indexes": []
    },
    {
      "name": "Todo",
      "fields": [
        {
          "name": "title",
          "type": "string",
          "optional": false,
          "unique": false
        },
        {
          "name": "done",
          "type": "bool",
          "optional": false,
          "unique": false
        },
        {
          "name": "authorId",
          "type": "id(User)",
          "optional": false,
          "unique": false
        },
        {
          "name": "createdAt",
          "type": "datetime",
          "optional": false,
          "unique": false
        }
      ],
      "indexes": [
        {
          "name": "by_author",
          "fields": [
            "authorId"
          ],
          "unique": false
        }
      ]
    }
  ],
  "routes": [
    {
      "path": "/",
      "mode": "server",
      "query": "allTodos",
      "auth": "public"
    },
    {
      "path": "/todos",
      "mode": "live",
      "query": "todosByAuthor",
      "auth": "user"
    },
    {
      "path": "/todos/:todoId",
      "mode": "server",
      "query": "todoById",
      "auth": "user"
    }
  ],
  "queries": [
    {
      "name": "todosByAuthor",
      "input": [
        {
          "name": "authorId",
          "type": "id(User)",
          "optional": false,
          "unique": false
        }
      ]
    },
    {
      "name": "allTodos",
      "input": [
        {
          "name": "done",
          "type": "bool",
          "optional": true,
          "unique": false
        }
      ]
    },
    {
      "name": "todoById",
      "input": [
        {
          "name": "todoId",
          "type": "id(Todo)",
          "optional": false,
          "unique": false
        }
      ]
    }
  ],
  "actions": [
    {
      "name": "createTodo",
      "input": [
        {
          "name": "title",
          "type": "string",
          "optional": false,
          "unique": false
        },
        {
          "name": "authorId",
          "type": "id(User)",
          "optional": false,
          "unique": false
        }
      ]
    },
    {
      "name": "toggleTodo",
      "input": [
        {
          "name": "todoId",
          "type": "id(Todo)",
          "optional": false,
          "unique": false
        }
      ]
    }
  ],
  "policies": [
    {
      "name": "authenticatedCreate",
      "allow": "auth.userId != null",
      "action": "createTodo"
    },
    {
      "name": "ownerToggle",
      "allow": "auth.userId == input.authorId",
      "action": "toggleTodo"
    },
    {
      "name": "ownerReadTodos",
      "allow": "auth.userId == data.authorId",
      "entity": "Todo"
    }
  ]
}
